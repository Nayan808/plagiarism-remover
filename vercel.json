{
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/process", "destination": "/api/index" },
    { "source": "/",        "destination": "/frontend/index.html" },
    { "source": "/(.*)",    "destination": "/frontend/$1" }
  ]
}
